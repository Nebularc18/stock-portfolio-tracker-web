# Finnhub API Key
# Get your free API key at https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key_here

# Backend auth/bootstrap settings for local docker-compose
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=change_me_local_password
POSTGRES_DB=portfolio
DATABASE_URL=postgresql://portfolio:change_me_local_password@postgres:5432/portfolio
DEFAULT_USERNAME=admin
DEFAULT_PASSWORD=admin123
GUEST_USERNAME=guest
GUEST_PASSWORD=
AUTH_TOKEN_SECRET=replace_with_a_long_random_secret
AUTH_TOKEN_TTL_SECONDS=43200

# Optional market data keys
MARKETSTACK_API_KEY=
